# Server
PORT=3001
NODE_ENV=development

# Database
# Local dev: use individual vars below
# Railway: DATABASE_URL is auto-provided by the Postgres plugin
DATABASE_URL=
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=your_password
DATABASE_NAME=kanflow_db

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret
JWT_REFRESH_EXPIRES_IN=30d

# OAuth2 Google
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Local: http://localhost:3001/api/v1/auth/google/callback
# Railway: https://your-backend.railway.app/api/v1/auth/google/callback
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback

# Stripe (optional — app works in dummy mode without these)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRO_PRICE_ID_MONTHLY=price_your_pro_monthly_price_id
STRIPE_PRO_PRICE_ID_ANNUAL=price_your_pro_annual_price_id

# Redis (currently disabled)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Email — Resend API (replaces Gmail SMTP due to Railway network restrictions)
# Get your API key at: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=KanFlow <onboarding@resend.dev>
APP_NAME=KanFlow

# Sales
SALES_EMAIL=your-email@gmail.com

# Frontend
# Local: http://localhost:3000
# Railway: https://your-frontend.railway.app
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# Features
INVITE_FEATURE_ENABLED=true

# Invitations
INVITATION_BASE_URL=http://localhost:3000

# File Upload
# Railway: set to /app/uploads and add a Railway Volume mounted at /app/uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880
