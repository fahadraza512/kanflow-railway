# API Configuration
# CRITICAL: Set to true to use API backend instead of localStorage
# Railway Production: MUST be set to true in Railway environment variables
NEXT_PUBLIC_USE_API=true
NEXT_PUBLIC_API_URL=http://localhost:3005/api/v1

# Feature Flags
NEXT_PUBLIC_ENABLE_MOCK_DATA=false
NEXT_PUBLIC_INVITE_FEATURE_ENABLED=true

# Environment
NODE_ENV=development
